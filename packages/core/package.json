{
  "name": "@glazelab/core",
  "version": "0.0.0",
  "description": "WebGL liquid-glass primitive for the web. Default entry: Mode A static-image / Mode B live-element / auto-detection. /full entry adds Mode C DOM rasterization.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./full": {
      "types": "./dist/full.d.ts",
      "import": "./dist/full.js",
      "require": "./dist/full.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "lint": "echo 'lint: TODO (eslint config pending)'"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.6",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "size-limit": [
    {
      "name": "@glazelab/core (default entry)",
      "path": "dist/index.js",
      "limit": "15 KB"
    },
    {
      "name": "@glazelab/core/full",
      "path": "dist/full.js",
      "limit": "22 KB"
    }
  ],
  "publishConfig": {
    "access": "public"
  }
}
