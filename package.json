{
  "name": "glaze-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Glazelab monorepo — @glazelab/core, framework wrappers, and the playground.",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "corepack pnpm --filter playground dev",
    "build": "corepack pnpm -r build",
    "build:core": "corepack pnpm --filter @glazelab/core build",
    "build:playground": "corepack pnpm --filter playground build",
    "lint": "corepack pnpm -r lint",
    "size": "corepack pnpm --filter @glazelab/core size",
    "typecheck": "corepack pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
